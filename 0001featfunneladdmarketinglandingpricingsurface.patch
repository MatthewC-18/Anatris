+      {/* Hero */}
+      <section className="mx-auto max-w-3xl px-6 pb-10 pt-16 text-center">
+        <span className="inline-block rounded-full border border-slate-800 bg-slate-900/60 px-3 py-1 text-xs font-medium text-slate-400">
